<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ElectricityBill" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary = bright yellow in dark -->
        <item name="colorPrimary">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/bg2_dark</item>
        <item name="colorPrimaryContainer">@color/accent_bg_dark</item>
        <item name="colorOnPrimaryContainer">@color/text0_dark</item>

        <item name="colorSecondary">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/bg2_dark</item>
        <item name="colorSecondaryContainer">@color/accent_bg_dark</item>
        <item name="colorOnSecondaryContainer">@color/text0_dark</item>

        <!-- Surface = dark cards -->
        <item name="colorSurface">@color/bg0_dark</item>
        <item name="colorOnSurface">@color/text0_dark</item>
        <item name="colorSurfaceVariant">@color/bg2_dark</item>
        <item name="colorOnSurfaceVariant">@color/text1_dark</item>

        <item name="android:colorBackground">@color/bg2_dark</item>
        <item name="colorOutline">#28FFFFFF</item>

        <item name="android:statusBarColor">@color/bg0_dark</item>
        <item name="android:navigationBarColor">@color/bg0_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
