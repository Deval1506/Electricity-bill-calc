<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ElectricityBill" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary = yellow accent -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/text0_light</item>
        <item name="colorPrimaryContainer">@color/accent_bg</item>
        <item name="colorOnPrimaryContainer">@color/text0_light</item>

        <!-- Secondary mirrors primary -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/text0_light</item>
        <item name="colorSecondaryContainer">@color/accent_bg</item>
        <item name="colorOnSecondaryContainer">@color/text0_light</item>

        <!-- Surface = white cards -->
        <item name="colorSurface">@color/bg0_light</item>
        <item name="colorOnSurface">@color/text0_light</item>
        <item name="colorSurfaceVariant">@color/bg2_light</item>
        <item name="colorOnSurfaceVariant">@color/text1_light</item>

        <!-- Window background = bg2 -->
        <item name="android:colorBackground">@color/bg2_light</item>

        <!-- Outline for inputs -->
        <item name="colorOutline">#28000000</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg0_light</item>
        <item name="android:navigationBarColor">@color/bg0_light</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
